  },
  "paper_highlights": {
    "stage1": [
      "Median zero-transition relative response changes from 0.527 to 0.043.",
      "Synthetic camera-shift responses are 3.6x to 8.3x smaller, depending on axis and aggregation.",
      "Shortcut leakage changes from 0.151 to 0.014 while the cross-episode same-primitive cosine preservation check remains 0.132 versus 0.131."
    ],
    "stage2": [
      "Own-latent rollout FDCE is reduced by 42% at 2B and 26% at 14B after rounding as reported in the manuscript.",
      "Target-latent-transfer FDCE is reduced by 21% at 2B and 34% at 14B after rounding."
    ],
    "stage3": [
      "Robot-action rollout FDCE mean is reduced by 35% at 2B and 30% at 14B after rounding.",
      "The 14B CD-LAM row improves on the 2B CD-LAM row in every Table-III column."
    ],
    "efficiency": {
      "baseline_reference_updates": 50000,
      "cd_lam_14b_reaches_reference_fdce_at_approximately": 3000,
      "cd_lam_14b_reaches_reference_psnr_at_approximately": 4000,
      "claim": "more than 12x fewer aligned robot-action adaptation optimizer updates to reach the reference",
      "qualification": "This is a metric-threshold update comparison under aligned data, batch size, and optimizer settings. It is not a wall-clock speedup and does not compare the final 6000-update checkpoint ratio."
    },
    "scope_warning": "The manuscript reports video fidelity and action-following metrics, not planning, policy, safety, or real-robot task-success results."
  }
