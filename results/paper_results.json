        {"objective": "without action-centric contrast", "psnr": 29.64, "fg_psnr": 26.57, "camera_shift_x": 0.134, "camera_shift_y": 0.101, "robot_action_fdce": 19.07},
        {"objective": "without zero-transition calibration", "psnr": 29.31, "fg_psnr": 26.48, "camera_shift_x": 0.637, "camera_shift_y": 0.637, "robot_action_fdce": 16.1, "footnote": "Although FDCE is lower on this split, the upstream camera-shift diagnostic fails; the manuscript does not interpret this as better action debiasing."}
