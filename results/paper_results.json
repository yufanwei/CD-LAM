          "cd_lam": 0.043
        },
        {
          "group": "zero_transition_response",
          "diagnostic": "absolute latent norm",
          "statistic": "median",
          "unit": "latent_norm",
          "dreamdojo_lam": 3.119,
          "cd_lam": 0.226
        },
        {
          "group": "camera_shift_robustness",
          "diagnostic": "horizontal synthetic translation",
