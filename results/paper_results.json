{
  "schema_version": 1,
  "paper": {
    "title": "Causally Debiased Latent Action Model for Embodied Action Conditioned World Models",
    "code_url": "https://github.com/yufanwei/CD-LAM",
    "project_url": "https://yufanwei.github.io/CD-LAM-project-page/",
    "model_url": "https://huggingface.co/yufanwei/CD-LAM"
  },
  "status": {
    "provenance": "values transcribed from manuscript Tables I-V",
    "recomputed_by_this_release": false,
    "checkpoints_available": false,
    "note": "Public checkpoints and Hugging Face assets are pending upload; these fixtures are reference values, not fresh evaluation output."
  },
  "reporting_conventions": {
    "fdce": {
      "name": "Foreground Displacement Chamfer Error",
      "unit": "pixels at evaluation resolution",
      "direction": "lower_is_better",
      "max_valid_foreground_anchors_per_rollout_pair": 16,
      "foreground_backend": "SAM3",
      "tracking_backend": "CoWTracker",
      "track_distance": "c_ij = (1/H) * sum_s ||(p_hat_i^s - p_hat_i^0) - (p_j^s - p_j^0)||_2",
      "symmetric_chamfer": "FDCE = (1/(2*N_g))*sum_i min_j c_ij + (1/(2*N_r))*sum_j min_i c_ij"
    },
    "psnr": {
      "unit": "dB",
      "direction": "higher_is_better"
    },
    "ssim": {
      "direction": "higher_is_better"
    },
    "lpips": {
      "direction": "lower_is_better"
    }
  },
  "tables": {
    "table_i": {
      "title": "LAM action-irrelevant confounding audit",
      "protocol": {
        "unit_under_test": "LAM encoder alone",
        "world_model_rollout": false,
        "direction": "lower_is_better_for_all_rows",
        "shortcut_leakage_definition": "different-action same-episode distance gap relative to same-action different-episode pairs"
      },
      "rows": [
        {
          "group": "zero_transition_response",
          "diagnostic": "static duplicated-frame pair relative response",
          "statistic": "median",
          "unit": "relative_norm",
