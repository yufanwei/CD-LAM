# Copy to configs/paths.local.env and edit locally.
# Source this file from the repository root so the defaults remain relative.

export CDLAM_ROOT="${CDLAM_ROOT:-.}"
export CDLAM_DATA_ROOT="${CDLAM_DATA_ROOT:-$CDLAM_ROOT/data}"
export CDLAM_ARTIFACT_ROOT="${CDLAM_ARTIFACT_ROOT:-$CDLAM_ROOT/artifacts}"
export CDLAM_OUTPUT_ROOT="${CDLAM_OUTPUT_ROOT:-$CDLAM_ROOT/outputs}"
export CDLAM_CACHE_ROOT="${CDLAM_CACHE_ROOT:-$CDLAM_ROOT/.cache}"

# Required only for full training or rollout. Public CD-LAM model assets are
# pending upload; leave fields empty rather than guessing a filename.
export CDLAM_BASE_ACWM="${CDLAM_BASE_ACWM:-}"
export CDLAM_LAM_INIT="${CDLAM_LAM_INIT:-}"
export CDLAM_STAGE1_LAM="${CDLAM_STAGE1_LAM:-}"
export CDLAM_STAGE2_ACWM="${CDLAM_STAGE2_ACWM:-}"
export CDLAM_BRIDGE_BUNDLE="${CDLAM_BRIDGE_BUNDLE:-}"
export CDLAM_STAGE3_ACWM="${CDLAM_STAGE3_ACWM:-}"
export CDLAM_UNLABELED_MANIFEST="${CDLAM_UNLABELED_MANIFEST:-}"
export CDLAM_ROBOT_ACTION_MANIFEST="${CDLAM_ROBOT_ACTION_MANIFEST:-}"
export CDLAM_EVAL_MANIFEST="${CDLAM_EVAL_MANIFEST:-}"

# Optional external dependencies. SAM3 is used for Stage-1 masks and FDCE;
# CoWTracker is used for FDCE only. Review their licenses before configuring.
export SAM3_ROOT="${SAM3_ROOT:-}"
export COWTRACKER_ROOT="${COWTRACKER_ROOT:-}"

export CDLAM_HF_REPO_ID="${CDLAM_HF_REPO_ID:-yufanwei/CD-LAM}"
export HF_HOME="${HF_HOME:-$CDLAM_CACHE_ROOT/huggingface}"
export PYTHON="${PYTHON:-python3}"
